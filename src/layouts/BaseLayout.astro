---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import data from '../data/site.json';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = `${data.site.name} ${data.site.badge} — ${data.site.tagline}`,
  description = 'Koonek HOP centralizes patients, appointments, health records, and prescriptions in a single AI-powered platform.',
  lang = 'es',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body data-lang={lang}>

  <!-- Custom cursor: sienna triangle + glacier dot, echoes the isotipo -->
  <div id="cur">
    <svg viewBox="0 0 24 26" width="24" height="26" fill="none">
      <g transform="rotate(-16 12 13)">
        <polygon points="12,2 19,17 5,17" fill="var(--moss)" stroke="rgba(20,15,10,.35)" stroke-width="0.6" stroke-linejoin="round"/>
        <circle cx="12" cy="21.5" r="2.4" fill="var(--ice)"/>
      </g>
    </svg>
  </div>

  <!-- Shared nav -->
  <Nav />

  <!-- Page content -->
  <slot />

  <!-- Shared footer -->
  <Footer />

  <!-- Boot all JS modules -->
  <script>
    import { initCursor } from '../scripts/cursor.js';
    import { initLang   } from '../scripts/i18n.js';
    import { initSplash } from '../scripts/splash.js';
    import { initReveal } from '../scripts/reveal.js';

    initCursor();
    initLang();
    initSplash();
    initReveal();
  </script>

</body>
</html>

<style lang="scss" is:global>
  @use '../styles/main.scss';
</style>
