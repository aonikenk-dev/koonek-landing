---
import Isotipo from './Isotipo.astro';
import data from '../data/site.json';
const { footer, site } = data;
---

<footer>
  <div class="ft-lockup">
    <div class="ft-imagotipo">
      <Isotipo size={22} />
      <div class="ft-logo">{site.name}<span class="dot">{site.badge}</span></div>
    </div>
    <div class="ft-slogan">{site.slogan}.</div>
  </div>

  <div class="ft-copy">
    © Crafted by <a href="https://aonikenk.dev" class="ft-credit">{site.by}</a> | <span id="current-year"></span> · {site.location}
  </div>

  <ul class="ft-links">
    <li>
      <a href="/#features" data-es>{footer.es.features}</a>
      <a href="/#features" data-en>{footer.en.features}</a>
    </li>
    <li>
      <a href="/#ai" data-es>{footer.es.ai}</a>
      <a href="/#ai" data-en>{footer.en.ai}</a>
    </li>
    <li>
      <a href="/#about" data-es>{footer.es.about}</a>
      <a href="/#about" data-en>{footer.en.about}</a>
    </li>
    <li>
      <a href="/#contact" data-es>{footer.es.contact}</a>
      <a href="/#contact" data-en>{footer.en.contact}</a>
    </li>
  </ul>

  <!-- <a href="https://aonikenk.dev" class="ft-credit">
    {site.by}
  </a> -->
</footer>

<script>
  const el = document.getElementById('current-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style lang="scss">
  @use '../styles/tokens' as *;

  footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 32px 48px;
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;
  }
  .ft-imagotipo { display:flex; align-items:center; gap:8px; }
  .ft-lockup { display:flex; flex-direction:column; gap:0px; }
  .ft-logo {
    font-family: $font-display; font-weight: 800; font-size: 14px;
    color: var(--text); letter-spacing: -0.04em;
    display: flex; align-items: baseline;
    .dot { color: var(--moss); font-family: $font-mono; font-weight: 400; font-size: 9px; margin-left: 4px; }
  }
  .ft-slogan {
    font-family: $font-mono;
    font-size:8px;
    font-style:italic;
    letter-spacing:.08em;
    color:var(--subtle);
    padding-left:27px;
  }
  .ft-copy  { font-size: 10px; letter-spacing: .1em; color: var(--muted); }
  .ft-links {
    display: flex; gap: 24px; list-style: none;
    a { font-size: 10px; letter-spacing: .15em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color .2s; &:hover { color: var(--moss); } }
  }
  .ft-credit {
    font-size: 10px; letter-spacing: .15em; text-transform: uppercase;
    color: var(--sienna); text-decoration: none;
  }

  @media(max-width: $bp-mobile) {
    footer { flex-direction: column; text-align: center; }
    .ft-links { display: none; }
  }
</style>
