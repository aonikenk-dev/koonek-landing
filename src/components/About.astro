---
import data from '../data/site.json';
const { about } = data;
---

<section id="about" class="content">
  <div class="s-inner">
    <div class="reveal">
      <div class="eyebrow" data-es>{about.es.eyebrow}</div>
      <div class="eyebrow" data-en>{about.en.eyebrow}</div>
      <h2 class="s-title" data-es>{about.es.title}</h2>
      <h2 class="s-title" data-en>{about.en.title}</h2>
    </div>

    <div class="about-manifesto reveal" style="margin-top:40px;">
      <p data-es>{about.es.manifesto}</p>
      <p data-en>{about.en.manifesto}</p>
    </div>
  </div>
</section>
